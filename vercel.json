{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/gas/(.*)",
      "destination": "https://script.google.com/macros/s/$GAS_DEPLOYMENT_ID/exec"
    },
    {
      "source": "/api/gas",
      "destination": "https://script.google.com/macros/s/$GAS_DEPLOYMENT_ID/exec"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
